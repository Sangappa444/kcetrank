<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vidyari KCET | Admin Command Center</title>
  
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Google+Sans:wght@400;500;700&display=swap');
    
    :root {
      --md-sys-color-primary: #1a73e8;
      --md-sys-color-primary-container: #e8f0fe;
      --md-sys-color-on-primary-container: #174ea6;
      --md-sys-color-surface: #ffffff;
      --md-sys-color-surface-container: #f8fafc;
      --md-sys-color-surface-variant: #e2e8f0;
      --md-sys-color-on-surface: #1e293b;
      --md-sys-color-on-surface-variant: #64748b;
      --md-sys-color-outline: #cbd5e1;
      --md-sys-color-success: #137333;
      --md-sys-color-success-container: #e6f4ea;
      --md-sys-color-warning: #b06000;
      --md-sys-color-warning-container: #fef7e0;
      --md-sys-color-error: #c5221f;
      --md-sys-color-error-container: #fce8e6;
      
      --md-shape-corner-small: 8px;
      --md-shape-corner-medium: 16px;
      --md-shape-corner-large: 24px;
      
      --md-elevation-1: 0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1);
      --md-elevation-2: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -2px rgba(0,0,0,0.05);
      --md-elevation-3: 0 10px 15px -3px rgba(0,0,0,0.05), 0 4px 6px -4px rgba(0,0,0,0.05);
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Google Sans', 'Roboto', sans-serif;
    }
    
    body {
      background-color: #f1f5f9;
      color: var(--md-sys-color-on-surface);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    
    /* Top Navbar */
    .top-nav {
      height: 64px;
      background-color: var(--md-sys-color-surface);
      border-bottom: 1px solid var(--md-sys-color-outline);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: var(--md-sys-color-on-surface);
      font-weight: 700;
      font-size: 20px;
    }
    
    .nav-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    
    .nav-admin-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--md-sys-color-error-container);
      color: var(--md-sys-color-error);
      padding: 6px 12px;
      border-radius: 9999px;
      font-size: 13px;
      font-weight: 700;
    }
    
    .logout-btn {
      background: none;
      border: none;
      color: var(--md-sys-color-on-surface-variant);
      cursor: pointer;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: var(--md-shape-corner-small);
      transition: background 0.2s;
    }
    
    .logout-btn:hover {
      background: var(--md-sys-color-surface-variant);
    }
    
    /* Layout styling */
    .app-container {
      display: flex;
      flex: 1;
    }
    
    /* Side navigation rail */
    .side-rail {
      width: 240px;
      background-color: var(--md-sys-color-surface);
      border-right: 1px solid var(--md-sys-color-outline);
      display: flex;
      flex-direction: column;
      padding: 24px 8px;
      gap: 4px;
    }
    
    .rail-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 9999px;
      text-decoration: none;
      color: var(--md-sys-color-on-surface-variant);
      font-weight: 500;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .rail-item:hover {
      background-color: var(--md-sys-color-surface-container);
      color: var(--md-sys-color-on-surface);
    }
    
    .rail-item.active {
      background-color: var(--md-sys-color-primary-container);
      color: var(--md-sys-color-on-primary-container);
      font-weight: 700;
    }
    
    /* Main Content Area */
    .main-content {
      flex: 1;
      padding: 32px 40px;
      overflow-y: auto;
    }
    
    .dashboard-panel {
      display: none;
      flex-direction: column;
      gap: 24px;
    }
    
    .dashboard-panel.active {
      display: flex;
    }
    
    /* Section Title */
    .panel-header {
      margin-bottom: 8px;
    }
    
    .panel-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--md-sys-color-on-surface);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .panel-subtitle {
      font-size: 14px;
      color: var(--md-sys-color-on-surface-variant);
      margin-top: 4px;
    }
    
    /* Metric Cards Grid */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }
    
    .metric-card {
      background: var(--md-sys-color-surface);
      border: 1px solid var(--md-sys-color-outline);
      border-radius: var(--md-shape-corner-medium);
      padding: 24px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      box-shadow: var(--md-elevation-1);
    }
    
    .metric-label {
      font-size: 13px;
      font-weight: 500;
      color: var(--md-sys-color-on-surface-variant);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .metric-value {
      font-size: 32px;
      font-weight: 700;
      margin-top: 8px;
      color: var(--md-sys-color-on-surface);
    }
    
    .metric-icon-bg {
      position: absolute;
      right: 16px;
      bottom: 16px;
      opacity: 0.08;
      color: var(--md-sys-color-primary);
    }
    
    .metric-card.revenue .metric-icon-bg {
      color: #137333;
    }
    
    .metric-card.requests .metric-icon-bg {
      color: #b06000;
    }
    
    /* Premium Data Tables */
    .table-card {
      background: var(--md-sys-color-surface);
      border: 1px solid var(--md-sys-color-outline);
      border-radius: var(--md-shape-corner-medium);
      box-shadow: var(--md-elevation-2);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    
    .table-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--md-sys-color-outline);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .table-title {
      font-size: 18px;
      font-weight: 700;
    }
    
    .table-search {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #f8fafc;
      border: 1px solid var(--md-sys-color-outline);
      border-radius: var(--md-shape-corner-small);
      padding: 6px 12px;
      width: 280px;
    }
    
    .table-search input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 13px;
      width: 100%;
      color: var(--md-sys-color-on-surface);
    }
    
    .responsive-table {
      overflow-x: auto;
      width: 100%;
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 14px;
    }
    
    th {
      background-color: #f8fafc;
      color: var(--md-sys-color-on-surface-variant);
      font-weight: 700;
      padding: 14px 24px;
      border-bottom: 1px solid var(--md-sys-color-outline);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    td {
      padding: 16px 24px;
      border-bottom: 1px solid var(--md-sys-color-outline);
      color: var(--md-sys-color-on-surface);
      vertical-align: middle;
    }
    
    tr:last-child td {
      border-bottom: none;
    }
    
    tr:hover td {
      background-color: #f8fafc;
    }
    
    /* Badges & Statuses */
    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 700;
      gap: 4px;
    }
    
    .status-badge.pro {
      background-color: var(--md-sys-color-primary-container);
      color: var(--md-sys-color-on-primary-container);
    }
    
    .status-badge.ultra-pro {
      background-color: #f3e8ff;
      color: #7c3aed;
    }
    
    .status-badge.pending {
      background-color: var(--md-sys-color-warning-container);
      color: var(--md-sys-color-warning);
    }
    
    .status-badge.progress {
      background-color: var(--md-sys-color-primary-container);
      color: var(--md-sys-color-on-primary-container);
    }
    
    .status-badge.resolved {
      background-color: var(--md-sys-color-success-container);
      color: var(--md-sys-color-success);
    }
    
    /* Action Controls */
    .action-select {
      padding: 6px 12px;
      border: 1px solid var(--md-sys-color-outline);
      border-radius: var(--md-shape-corner-small);
      font-size: 13px;
      outline: none;
      background: white;
      cursor: pointer;
      font-weight: 500;
      transition: border-color 0.2s;
    }
    
    .action-select:focus {
      border-color: var(--md-sys-color-primary);
    }
    
    /* Loading overlay */
    .loading-overlay {
      position: fixed;
      inset: 0;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(4px);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 1000;
    }
    
    .spinner {
      width: 48px;
      height: 48px;
      border: 4px solid var(--md-sys-color-outline);
      border-top-color: var(--md-sys-color-primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .empty-state {
      padding: 48px;
      text-align: center;
      color: var(--md-sys-color-on-surface-variant);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    
    .empty-icon {
      font-size: 40px;
      opacity: 0.5;
    }

    /* Mobile Responsiveness */
    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      color: var(--md-sys-color-on-surface);
      cursor: pointer;
      padding: 4px;
    }
    .sidebar-overlay {
      display: none;
    }
    
    @media (max-width: 768px) {
      .mobile-menu-btn {
        display: block;
      }
      .side-rail {
        position: fixed;
        left: -260px;
        top: 64px;
        height: calc(100vh - 64px);
        z-index: 50;
        transition: left 0.3s ease;
        box-shadow: 4px 0 10px rgba(0,0,0,0.1);
      }
      .side-rail.open {
        left: 0;
      }
      .sidebar-overlay.open {
        display: block;
        position: fixed;
        top: 64px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 40;
      }
      
      .main-content {
        padding: 16px; 
      }
      
      .top-nav {
        padding: 0 16px;
      }
      
      .nav-admin-badge {
        display: none; 
      }
      .logout-btn span {
        display: none; 
      }
      
      .metrics-grid {
        grid-template-columns: 1fr;
      }
      
      /* Make tables scrollable horizontally */
      .data-table-container {
        overflow-x: auto;
        border-radius: var(--md-shape-corner-small);
      }
      
      .filter-bar {
        flex-direction: column;
        align-items: stretch;
      }
      
      .search-wrapper {
        max-width: 100%;
      }
    }
  </style>
</head>
<body>

  <!-- Loading Indicator -->
  <div id="loading-indicator" class="loading-overlay">
    <div class="spinner"></div>
  </div>

  <!-- Navbar -->
  <nav class="top-nav">
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="mobile-menu-btn" onclick="toggleSidebar()" aria-label="Toggle Menu">
        <i data-lucide="menu" style="width: 24px; height: 24px;"></i>
      </button>
      <a href="/kcet" class="nav-brand">
        <div class="logo-icon-wrapper" style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #4f46e5, #7c3aed); display: flex; justify-content: center; align-items: center; color: white;">
          <i data-lucide="cpu" style="width: 18px; height: 18px;"></i>
        </div>
        <span>Vidyari Admin</span>
      </a>
    </div>
    
    <div class="nav-actions">
      <div class="nav-admin-badge">
        <i data-lucide="shield-check" style="width: 16px; height: 16px;"></i> Administrator Mode
      </div>
      <button class="logout-btn" onclick="handleLogout()">
        <i data-lucide="log-out" style="width: 16px; height: 16px;"></i> Exit
      </button>
    </div>
  </nav>

  <div class="app-container">
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>
    <!-- Sidebar Navigation -->
    <aside class="side-rail">
      <div class="rail-item active" onclick="switchPanel('overview')">
        <i data-lucide="layout-dashboard"></i> Overview & Metrics
      </div>
      <div class="rail-item" onclick="switchPanel('subscribers')">
        <i data-lucide="users"></i> Subscribers Directory
      </div>
      <div class="rail-item" onclick="switchPanel('requests')">
        <i data-lucide="heart-handshake"></i> Counseling Queue
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
      
      <!-- 1. OVERVIEW PANEL -->
      <section class="dashboard-panel active" id="panel-overview">
        <div class="panel-header">
          <h1 class="panel-title"><i data-lucide="bar-chart-2"></i> Platform Overview</h1>
          <p class="panel-subtitle">Real-time metrics, revenue metrics, and user logs.</p>
        </div>
        
        <div class="metrics-grid">
          <div class="metric-card">
            <span class="metric-label">Total Subscribed Users</span>
            <span class="metric-value" id="metric-total-subscribers">-</span>
            <i data-lucide="users" class="metric-icon-bg" style="width: 64px; height: 64px;"></i>
          </div>
          
          <div class="metric-card">
            <span class="metric-label">Pro Subscribers</span>
            <span class="metric-value" id="metric-pro-count">-</span>
            <i data-lucide="user-check" class="metric-icon-bg" style="width: 64px; height: 64px;"></i>
          </div>
          
          <div class="metric-card">
            <span class="metric-label">Ultra Pro Subscribers</span>
            <span class="metric-value" id="metric-ultra-pro-count">-</span>
            <i data-lucide="award" class="metric-icon-bg" style="width: 64px; height: 64px;"></i>
          </div>
          
          <div class="metric-card revenue">
            <span class="metric-label">Estimated Revenue</span>
            <span class="metric-value" id="metric-revenue">-</span>
            <i data-lucide="indian-rupee" class="metric-icon-bg" style="width: 64px; height: 64px;"></i>
          </div>
          
          <div class="metric-card requests">
            <span class="metric-label">Pending Requests</span>
            <span class="metric-value" id="metric-pending-requests">-</span>
            <i data-lucide="hourglass" class="metric-icon-bg" style="width: 64px; height: 64px;"></i>
          </div>
        </div>
      </section>

      <!-- 2. SUBSCRIBERS DIRECTORY -->
      <section class="dashboard-panel" id="panel-subscribers">
        <div class="panel-header">
          <h1 class="panel-title"><i data-lucide="users"></i> Subscribers Directory</h1>
          <p class="panel-subtitle">Listing of all registered Pro and Ultra Pro users.</p>
        </div>
        
        <div class="table-card">
          <div class="table-header">
            <span class="table-title">Subscribed Users</span>
            <div class="table-search">
              <i data-lucide="search" style="width: 16px; height: 16px; color: var(--md-sys-color-on-surface-variant);"></i>
              <input type="text" id="search-subscribers" placeholder="Search by name, email, phone..." oninput="filterSubscribersTable()">
            </div>
          </div>
          
          <div class="responsive-table">
            <table id="subscribers-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Rank</th>
                  <th>Category</th>
                  <th>Plan Level</th>
                  <th>Saved Options</th>
                </tr>
              </thead>
              <tbody id="subscribers-list-body">
                <!-- Injected dynamically -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- 3. COUNSELOR QUEUE -->
      <section class="dashboard-panel" id="panel-requests">
        <div class="panel-header">
          <h1 class="panel-title"><i data-lucide="heart-handshake"></i> Counseling Queue</h1>
          <p class="panel-subtitle">Manual Option Entry planner requests from Ultra Pro members.</p>
        </div>
        
        <div class="table-card">
          <div class="table-header">
            <span class="table-title">Requests Queue</span>
            <div class="table-search">
              <i data-lucide="search" style="width: 16px; height: 16px; color: var(--md-sys-color-on-surface-variant);"></i>
              <input type="text" id="search-requests" placeholder="Search by name, stream, status..." oninput="filterRequestsTable()">
            </div>
          </div>
          
          <div class="responsive-table">
            <table id="requests-table">
              <thead>
                <tr>
                  <th>User Details</th>
                  <th>Phone Number</th>
                  <th>Preferred Stream</th>
                  <th>Special Preferences / Comments</th>
                  <th>Request Date</th>
                  <th>Current Status</th>
                  <th>Action Controls</th>
                </tr>
              </thead>
              <tbody id="requests-list-body">
                <!-- Injected dynamically -->
              </tbody>
            </table>
          </div>
        </div>
      </section>

    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="/kcet/js/KCETadmin.js"></script>
  <script>
    function toggleSidebar() {
      const rail = document.querySelector('.side-rail');
      const overlay = document.getElementById('sidebar-overlay');
      if (rail && overlay) {
        rail.classList.toggle('open');
        overlay.classList.toggle('open');
      }
    }

    // Close sidebar on menu item click (mobile)
    document.querySelectorAll('.rail-item').forEach(item => {
      item.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          toggleSidebar();
        }
      });
    });
  </script>
</body>
</html>
