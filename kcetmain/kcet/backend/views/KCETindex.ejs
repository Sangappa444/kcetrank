  <!-- Floating Action Bar for Compare -->
  <div id="compare-action-bar" style="display: none; position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #1e293b; color: white; padding: 12px 24px; border-radius: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); z-index: 1000; align-items: center; gap: 16px;">
    <span id="compare-count-text" style="font-weight: 600; font-size: 14px;">0 Selected</span>
    <button id="compare-btn" style="background: #3b82f6; color: white; border: none; padding: 6px 16px; border-radius: 20px; font-weight: 600; cursor: pointer;">Compare Now</button>
    <button id="compare-clear-btn" style="background: transparent; color: #cbd5e1; border: none; cursor: pointer; text-decoration: underline; font-size: 13px;">Clear</button>
  </div>

  <!-- Compare Modal -->
  <div id="compare-modal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center;">
    <div style="background: white; width: 90%; max-width: 900px; border-radius: 16px; padding: 24px; max-height: 90vh; overflow-y: auto;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 style="font-size: 20px; font-weight: 700; color: #0f172a;">Compare Colleges</h2>
        <button id="close-compare-modal" style="background: none; border: none; cursor: pointer;"><i data-lucide="x" style="width: 24px; height: 24px;"></i></button>
      </div>
      <div id="compare-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
        <!-- Compare columns injected here -->
      </div>
    </div>
  </div>

  <!-- Floating Wishlist Button -->
  <button id="floating-wishlist-btn" style="position: fixed; bottom: 20px; right: 20px; background: #ec4899; color: white; border: none; border-radius: 50%; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(236, 72, 153, 0.4); cursor: pointer; z-index: 900;">
    <i data-lucide="heart" style="width: 24px; height: 24px; fill: white;"></i>
    <span id="wishlist-badge" style="position: absolute; top: -4px; right: -4px; background: #1e293b; color: white; font-size: 12px; font-weight: bold; border-radius: 12px; padding: 2px 6px; display: none;">0</span>
  </button>

  <!-- Wishlist / Option Entry Modal -->
  <div id="wishlist-modal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center;">
    <div style="background: white; width: 90%; max-width: 600px; border-radius: 16px; padding: 24px; max-height: 90vh; display: flex; flex-direction: column;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <div>
          <h2 style="font-size: 20px; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px;"><i data-lucide="list-ordered" style="width: 22px; height: 22px; color: #4f46e5;"></i> My Option Entry List</h2>
          <p style="font-size: 13px; color: #64748b; margin-top: 4px;">Drag and drop to set your priority order. This exact order will print on your PDF.</p>
        </div>
        <button id="close-wishlist-modal" style="background: none; border: none; cursor: pointer;"><i data-lucide="x" style="width: 24px; height: 24px;"></i></button>
      </div>
      <div id="wishlist-sortable-list" style="flex: 1; overflow-y: auto; padding-right: 8px; display: flex; flex-direction: column; gap: 10px;">
        <!-- Sortable items injected here -->
      </div>
      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
        <button id="clear-wishlist-btn" style="color: #ef4444; background: none; border: none; font-weight: 600; cursor: pointer;">Clear All</button>
        <button id="download-wishlist-btn" style="background: #10b981; color: white; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;">
          <i data-lucide="download" style="width: 18px; height: 18px;"></i> Download PDF
        </button>
      </div>
    </div>
  </div>

