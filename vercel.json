{
  "version": 2,
  "builds": [
    {
      "src": "kcetmain/kcet/backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "kcetmain/kcet/backend/views/**",
          "kcetmain/kcet/backend/public/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "kcetmain/kcet/backend/server.js"
    }
  ]
}
