<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KCET Multi-Course Predictor</title>
    <link rel="stylesheet" href="/css/index.css">
    
    <!-- Axios for AJAX -->
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <!-- Lucide for Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- jsPDF and AutoTable for Reports -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
</head>
<body>
    <div class="app-container">
        <header>
            <h1>KCET Multi-Course Predictor</h1>
            <p class="subtitle">Check your admission chances across Engineering, Agriculture, Veterinary, Pharmacy, Nursing, BNYS, Allied Health, BPT, and BPO in Karnataka</p>
        </header>

        <div class="category-tabs-container">
            <h2 class="section-title">Select Admission Stream</h2>
            <div class="category-tabs" id="tabs-container">
                <!-- Tabs will load dynamically here -->
            </div>
        </div>

        <div class="glass-panel">
            <form class="search-form" id="searchForm">
                <div class="form-group region-selector-group" style="grid-column: 1 / -1;">
                    <label>Quota Region</label>
                    <div class="region-toggle">
                        <button 
                            type="button" 
                            id="rk-btn"
                            class="region-btn active"
                            onclick="setRegion('RK')"
                        >
                            Rest of Karnataka (General Quota)
                        </button>
                        <button 
                            type="button" 
                            id="hk-btn"
                            class="region-btn"
                            onclick="setRegion('HK')"
                        >
                            Kalyana-Karnataka (371j Quota)
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="rank">Your KCET Rank</label>
                    <input 
                        type="number" 
                        id="rank" 
                        placeholder="e.g., 15000" 
                        required
                        min="1"
                    />
                </div>
                
                <div class="form-group">
                    <label for="category">Quota Category</label>
                    <select id="category">
                        <!-- Categories will populate here -->
                    </select>
                </div>

                <div class="form-group">
                    <label for="course" id="course-label">Preferred Course (Optional)</label>
                    <select id="course">
                        <option value="">All Courses</option>
                        <!-- Courses will populate here -->
                    </select>
                </div>

                <button type="submit" class="btn" id="submit-btn">
                    <i data-lucide="search" style="width: 18px; height: 18px;"></i>
                    Find Match Cutoffs
                </button>
            </form>
        </div>

        <div id="results-section" style="display: none;">
            <!-- Predictions/Payment card will render here dynamically -->
        </div>
    </div>

    <script>
        const rkCategories = [
            '1G', '1K', '1R', '2AG', '2AK', '2AR', '2BG', '2BK', '2BR', 
            '3AG', '3AK', '3AR', '3BG', '3BK', '3BR', 
            'GM', 'GMK', 'GMR', 'SCG', 'SCK', 'SCR', 'STG', 'STK', 'STR'
        ];

        const hkCategories = [
            '1H', '1KH', '1RH', '2AH', '2AKH', '2ARH', '2BH', '2BKH', '2BRH', 
            '3AH', '3AKH', '3ARH', '3BH', '3BKH', '3BRH', 
            'GMH', 'GMKH', 'GMRH', 'SCH', 'SCKH', 'SCRH', 'STH', 'STKH', 'STRH'
        ];

        const categoryIcons = {
            'Engineering': 'cpu',
            'Agriculture': 'leaf',
            'Veterinary': 'award',
            'B.Pharm': 'pill',
            'D.Pharm': 'pill',
            'B.Sc Nursing': 'heart-pulse',
            'BNYS': 'activity',
            'Allied Health Sciences': 'stethoscope',
            'BPT': 'graduation-cap',
            'BPO': 'stethoscope',
            'Architecture': 'compass'
        };

        let activeCategory = 'Engineering';
        let categories = [];
        let courses = [];
        let results = [];
        let quotaRegion = 'RK';
        let paymentSuccess = false;
        let paymentLoading = false;
        let pdfLoading = false;
        let searched = false;

        document.addEventListener('DOMContentLoaded', async () => {
            // Fetch categories list
            try {
                const res = await axios.get('/api/categories');
                categories = res.data;
            } catch (err) {
                console.error("Error fetching categories:", err);
                categories = [
                    'Engineering', 'Agriculture', 'Veterinary', 'B.Pharm', 'D.Pharm',
                    'B.Sc Nursing', 'BNYS', 'Allied Health Sciences', 'BPT', 'BPO', 'Architecture'
                ];
            }

            renderCategoryTabs();
            updateCategoryDropdown();
            loadCourses();
        });

        function renderCategoryTabs() {
            const container = document.getElementById('tabs-container');
            let html = '';
            categories.forEach(cat => {
                const iconName = categoryIcons[cat] || 'book-open';
                const activeClass = activeCategory === cat ? 'active' : '';
                html += `
                    <button 
                        type="button" 
                        class="category-tab ${activeClass}" 
                        onclick="setActiveCategory('${cat}')"
                    >
                        <span class="tab-icon"><i data-lucide="${iconName}" style="width: 18px; height: 18px;"></i></span>
                        <span class="tab-label">${cat}</span>
                    </button>
                `;
            });
            container.innerHTML = html;
            lucide.createIcons();
        }

        function setActiveCategory(cat) {
            activeCategory = cat;
            document.getElementById('results-section').style.display = 'none';
            searched = false;
            paymentSuccess = false;
            
            // Re-render tabs
            renderCategoryTabs();
            
            // Update label
            document.getElementById('course-label').textContent = `Preferred ${cat} Course (Optional)`;
            
            loadCourses();
        }

        async function loadCourses() {
            const courseSelect = document.getElementById('course');
            courseSelect.innerHTML = `<option value="">Loading courses...</option>`;
            try {
                const res = await axios.get(`/api/courses?category=${activeCategory}`);
                courses = res.data;
                let html = `<option value="">All ${activeCategory} Courses</option>`;
                courses.forEach(c => {
                    html += `<option value="${c}">${c}</option>`;
                });
                courseSelect.innerHTML = html;
            } catch (err) {
                console.error(err);
                courseSelect.innerHTML = `<option value="">Error loading courses</option>`;
            }
        }

        function setRegion(region) {
            quotaRegion = region;
            document.getElementById('results-section').style.display = 'none';
            searched = false;
            paymentSuccess = false;

            if (region === 'RK') {
                document.getElementById('rk-btn').classList.add('active');
                document.getElementById('hk-btn').classList.remove('active');
            } else {
                document.getElementById('hk-btn').classList.add('active');
                document.getElementById('rk-btn').classList.remove('active');
            }

            updateCategoryDropdown();
        }

        function updateCategoryDropdown() {
            const categorySelect = document.getElementById('category');
            const list = quotaRegion === 'RK' ? rkCategories : hkCategories;
            let html = '';
            list.forEach(c => {
                html += `<option value="${c}">${c}</option>`;
            });
            categorySelect.innerHTML = html;
        }

        // Form Submission
        document.getElementById('searchForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const rankVal = document.getElementById('rank').value;
            const catVal = document.getElementById('category').value;
            const courseVal = document.getElementById('course').value;
            const submitBtn = document.getElementById('submit-btn');
            
            if (!rankVal || !catVal) return;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Evaluating...';

            const resultsContainer = document.getElementById('results-section');
            resultsContainer.style.display = 'block';
            resultsContainer.innerHTML = `
                <div class="empty-state">
                    <div class="spinner">Evaluating college criteria...</div>
                </div>
            `;
            
            try {
                const res = await axios.get(`/api/predict`, {
                    params: {
                        rank: rankVal,
                        category: catVal,
                        course_name: courseVal,
                        course_category: activeCategory
                    }
                });
                results = res.data;
                searched = true;
                paymentSuccess = false;
                renderResults();
            } catch (err) {
                console.error(err);
                resultsContainer.innerHTML = `
                    <div class="glass-panel empty-state">
                        <h3>Error evaluating options</h3>
                        <p>Please try again later.</p>
                    </div>
                `;
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = `<i data-lucide="search" style="width: 18px; height: 18px;"></i> Find Match Cutoffs`;
                lucide.createIcons();
            }
        });

        function renderResults() {
            const resultsContainer = document.getElementById('results-section');
            if (results.length === 0) {
                resultsContainer.innerHTML = `
                    <div class="glass-panel empty-state">
                        <i data-lucide="compass" class="empty-icon" style="width: 48px; height: 48px;"></i>
                        <h3>No colleges found in this range</h3>
                        <p>Try modifying your category or rank preferences.</p>
                    </div>
                `;
                lucide.createIcons();
                return;
            }
            
            const rankVal = document.getElementById('rank').value;
            const catVal = document.getElementById('category').value;
            const courseVal = document.getElementById('course').value;
            
            if (!paymentSuccess) {
                resultsContainer.innerHTML = `
                    <div class="payment-panel">
                        <h2>
                            <i data-lucide="lock" style="color: #6366f1; width: 24px; height: 24px;"></i>
                            Unlock Cutoff Report
                        </h2>
                        <p class="payment-description">
                            We evaluated your rank of <strong>${rankVal}</strong> for <strong>${activeCategory}</strong>. We found <strong>${results.length} matching colleges</strong> based on your preferences. Complete payment to download the detailed PDF report.
                        </p>

                        <div class="payment-details-card">
                            <div class="payment-detail-item">
                                <span class="payment-detail-label">Your Rank</span>
                                <span class="payment-detail-value">${rankVal}</span>
                            </div>
                            <div class="payment-detail-item">
                                <span class="payment-detail-label">Category</span>
                                <span class="payment-detail-value">${catVal}</span>
                            </div>
                            <div class="payment-detail-item">
                                <span class="payment-detail-label">Matched Options</span>
                                <span class="payment-detail-value highlight">${results.length}</span>
                            </div>
                        </div>

                        <div class="payment-features-list">
                            <div class="payment-feature-item">
                                <span class="payment-feature-icon"><i data-lucide="check-circle-2" style="width: 16px; height: 16px;"></i></span>
                                <span>Detailed PDF report for <strong>${courseVal || 'All Courses'}</strong></span>
                            </div>
                            <div class="payment-feature-item">
                                <span class="payment-feature-icon"><i data-lucide="check-circle-2" style="width: 16px; height: 16px;"></i></span>
                                <span>Accurate KEA cutoff rounds history (2023, 2024, and 2025)</span>
                            </div>
                            <div class="payment-feature-item">
                                <span class="payment-feature-icon"><i data-lucide="check-circle-2" style="width: 16px; height: 16px;"></i></span>
                                <span>Admission chances analysis (Safe / Moderate / Tough)</span>
                            </div>
                            <div class="payment-feature-item">
                                <span class="payment-feature-icon"><i data-lucide="check-circle-2" style="width: 16px; height: 16px;"></i></span>
                                <span>Region-wise rest of Karnataka and Hyderabad-Karnataka quotas</span>
                            </div>
                        </div>

                        <button 
                            onclick="handlePayment()" 
                            id="pay-btn"
                            class="btn-pay"
                        >
                            <i data-lucide="credit-card" style="width: 18px; height: 18px;"></i>
                            Pay ₹99 & Download PDF
                        </button>
                    </div>
                `;
            } else {
                resultsContainer.innerHTML = `
                    <div class="payment-panel payment-success-card">
                        <h2 class="payment-unlocked-header">
                            <i data-lucide="check-circle-2" style="width: 28px; height: 28px;"></i>
                            Payment Successful!
                        </h2>
                        <p class="payment-description">
                            Thank you! Your transaction was completed successfully. Your PDF cutoff report has been generated. If the download did not start automatically, please click below.
                        </p>
                        
                        <button 
                            onclick="generatePDF()" 
                            id="pdf-download-btn"
                            class="btn" 
                            style="background: #10b981; min-width: 250px; height: 52px; font-size: 1.05rem;"
                        >
                            <i data-lucide="download" style="width: 18px; height: 18px;"></i>
                            Download Cutoff Report
                        </button>
                    </div>
                `;
            }
            lucide.createIcons();
        }

        const loadRazorpayScript = () => {
            return new Promise((resolve) => {
                if (window.Razorpay) {
                    resolve(true);
                    return;
                }
                const script = document.createElement('script');
                script.src = 'https://checkout.razorpay.com/v1/checkout.js';
                script.onload = () => resolve(true);
                script.onerror = () => resolve(false);
                document.body.appendChild(script);
            });
        };

        async function handlePayment() {
            const payBtn = document.getElementById('pay-btn');
            payBtn.disabled = true;
            payBtn.innerHTML = 'Processing...';
            
            try {
                const scriptLoaded = await loadRazorpayScript();
                if (!scriptLoaded) {
                    alert("Failed to load Razorpay SDK. Please check your internet connection.");
                    payBtn.disabled = false;
                    payBtn.innerHTML = `<i data-lucide="credit-card" style="width: 18px; height: 18px;"></i> Pay ₹99 & Download PDF`;
                    lucide.createIcons();
                    return;
                }
                
                // Create order
                const orderRes = await axios.post('/api/payment/order');
                const { id: order_id, amount, currency } = orderRes.data;
                
                const rankVal = document.getElementById('rank').value;
                
                const options = {
                    key: "rzp_test_SsfEoEMxq5grVv",
                    amount: amount,
                    currency: currency,
                    name: "KCET Predictor",
                    description: `Unlock Cutoff Report (Rank ${rankVal})`,
                    order_id: order_id,
                    handler: async function (response) {
                        try {
                            // Verify payment
                            const verifyRes = await axios.post('/api/payment/verify', {
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_signature: response.razorpay_signature
                            });
                            
                            if (verifyRes.data.status === 'success') {
                                paymentSuccess = true;
                                renderResults();
                                setTimeout(() => {
                                    generatePDF();
                                }, 500);
                            } else {
                                alert("Payment verification failed.");
                                payBtn.disabled = false;
                                payBtn.innerHTML = `<i data-lucide="credit-card" style="width: 18px; height: 18px;"></i> Pay ₹99 & Download PDF`;
                                lucide.createIcons();
                            }
                        } catch (verifyErr) {
                            console.error("Verification error:", verifyErr);
                            alert("Verification failed: " + (verifyErr.response?.data?.error || verifyErr.message));
                            payBtn.disabled = false;
                            payBtn.innerHTML = `<i data-lucide="credit-card" style="width: 18px; height: 18px;"></i> Pay ₹99 & Download PDF`;
                            lucide.createIcons();
                        }
                    },
                    prefill: {
                        name: "",
                        email: "",
                        contact: ""
                    },
                    theme: {
                        color: "#6366f1"
                    }
                };
                
                const rzp = new window.Razorpay(options);
                rzp.on('payment.failed', function (resp) {
                    alert("Payment failed: " + resp.error.description);
                    payBtn.disabled = false;
                    payBtn.innerHTML = `<i data-lucide="credit-card" style="width: 18px; height: 18px;"></i> Pay ₹99 & Download PDF`;
                    lucide.createIcons();
                });
                rzp.open();
            } catch (err) {
                console.error("Payment initiation error:", err);
                alert("Failed to initiate payment: " + (err.response?.data?.error || err.message));
                payBtn.disabled = false;
                payBtn.innerHTML = `<i data-lucide="credit-card" style="width: 18px; height: 18px;"></i> Pay ₹99 & Download PDF`;
                lucide.createIcons();
            }
        }

        async function generatePDF() {
            const downloadBtn = document.getElementById('pdf-download-btn');
            if (downloadBtn) {
                downloadBtn.disabled = true;
                downloadBtn.innerHTML = 'Generating PDF...';
            }
            
            try {
                const rankVal = document.getElementById('rank').value;
                const catVal = document.getElementById('category').value;
                const courseVal = document.getElementById('course').value;
                
                const params = new URLSearchParams({ category: catVal });
                if (courseVal) params.append('course_name', courseVal);
                if (activeCategory) params.append('course_category', activeCategory);
                
                const response = await axios.get(`/api/cutoffs?${params.toString()}`);
                let rows = response.data;
                
                // Filter to only include college + course combinations present in the prediction results
                const allowedCombinations = new Set(results.map(r => `${r.college_code}|${r.course_name}`));
                rows = rows.filter(r => allowedCombinations.has(`${r.college_code}|${r.course_name}`));
                
                if (!rows || rows.length === 0) {
                    alert('No cutoff data available for the selected inputs.');
                    if (downloadBtn) {
                        downloadBtn.disabled = false;
                        downloadBtn.innerHTML = `<i data-lucide="download" style="width: 18px; height: 18px;"></i> Download Cutoff Report`;
                        lucide.createIcons();
                    }
                    return;
                }
                
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ orientation: 'landscape', format: 'a4' });
                
                const addPdfBranding = () => {
                    const totalPages = doc.internal.getNumberOfPages();
                    const pageWidth = doc.internal.pageSize.getWidth();
                    const pageHeight = doc.internal.pageSize.getHeight();
                    const footerText = `EDU YODHA | Generated on ${new Date().toLocaleString()}`;
                    
                    for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) {
                        doc.setPage(pageNumber);
                        
                        doc.saveGraphicsState();
                        doc.setGState(new doc.GState({ opacity: 0.04 }));
                        doc.setFont('helvetica', 'bold');
                        doc.setFontSize(42);
                        doc.setTextColor(45, 55, 72);
                        
                        for (let y = 18; y < pageHeight + 80; y += 58) {
                            for (let x = -35; x < pageWidth + 80; x += 105) {
                                doc.text('EDU YODHA', x, y, { angle: -28 });
                            }
                        }
                        
                        doc.restoreGraphicsState();
                        doc.setFont('helvetica', 'normal');
                        doc.setFontSize(9);
                        doc.setTextColor(100);
                        doc.text(footerText, 14, pageHeight - 10);
                        doc.text(`Page ${pageNumber} of ${totalPages}`, pageWidth - 34, pageHeight - 10);
                    }
                };
                
                doc.setFontSize(18);
                doc.text('KCET Cutoff History Report', 14, 20);
                doc.setFontSize(12);
                doc.text(`Category: ${catVal} | User Rank: ${rankVal} | Stream: ${activeCategory}`, 14, 28);
                if (courseVal) {
                    doc.text(`Preferred Course: ${courseVal}`, 14, 34);
                }
                doc.text('Full cutoff history for 2023, 2024, and 2025 (Rounds 1–3)', 14, 40);
                
                const grouped = {};
                rows.forEach(r => {
                    const key = `${r.college_name} \n(${r.course_name})`;
                    if (!grouped[key]) {
                        grouped[key] = {
                            name: key,
                            '2023_1': '-', '2023_2': '-', '2023_3': '-',
                            '2024_1': '-', '2024_2': '-', '2024_3': '-',
                            '2025_1': '-', '2025_2': '-', '2025_3': '-',
                        };
                    }
                    if (r.year && r.round) {
                        grouped[key][`${r.year}_${r.round}`] = r.cutoff_rank;
                    }
                });
                
                const getMinRank = (g) => {
                    const values = [
                        g['2023_1'], g['2023_2'], g['2023_3'],
                        g['2024_1'], g['2024_2'], g['2024_3'],
                        g['2025_1'], g['2025_2'], g['2025_3']
                    ]
                    .filter(v => v !== '-' && v !== null && v !== undefined)
                    .map(v => parseInt(v, 10))
                    .filter(Number.isFinite);
                    return values.length ? Math.min(...values) : Number.MAX_SAFE_INTEGER;
                };
                
                const getChance = (g) => {
                    const cutoffs = [
                        g['2023_1'], g['2023_2'], g['2023_3'],
                        g['2024_1'], g['2024_2'], g['2024_3'],
                        g['2025_1'], g['2025_2'], g['2025_3']
                    ]
                    .filter(v => v !== '-' && v !== null && v !== undefined)
                    .map(v => parseInt(v, 10))
                    .filter(Number.isFinite);
                    if (!cutoffs.length) return 'Tough';
                    const minCutoff = Math.min(...cutoffs);
                    const userRank = parseInt(rankVal, 10);
                    if (userRank <= minCutoff * 0.8) return 'Safe';
                    if (userRank <= minCutoff) return 'Moderate';
                    return 'Tough';
                };
                
                const getChanceColor = (chance) => {
                    if (chance === 'Safe') return [187, 247, 208];
                    if (chance === 'Moderate') return [254, 249, 195];
                    return [254, 202, 202];
                };
                
                const tableColumn = [
                    'College Name & Course',
                    'Chance',
                    '2023 R1', '2023 R2', '2023 R3',
                    '2024 R1', '2024 R2', '2024 R3',
                    '2025 R1', '2025 R2', '2025 R3'
                ];
                
                const tableRows = Object.values(grouped)
                .sort((a, b) => {
                    const aMin = getMinRank(a);
                    const bMin = getMinRank(b);
                    if (aMin !== bMin) return aMin - bMin;
                    return a.name.localeCompare(b.name);
                })
                .map(g => [
                    g.name,
                    getChance(g),
                    g['2023_1'], g['2023_2'], g['2023_3'],
                    g['2024_1'], g['2024_2'], g['2024_3'],
                    g['2025_1'], g['2025_2'], g['2025_3']
                ]);
                
                doc.autoTable({
                    startY: 52,
                    head: [tableColumn],
                    body: tableRows,
                    theme: 'grid',
                    styles: { fontSize: 8, cellPadding: 2 },
                    headStyles: { fillColor: [49, 46, 129], textColor: [255, 255, 255], halign: 'center' },
                    columnStyles: { 0: { cellWidth: 90 }, 1: { cellWidth: 30 } },
                    bodyStyles: { halign: 'center' },
                    didParseCell: data => {
                        if (data.section === 'body' && data.column.index === 0) {
                            data.cell.styles.halign = 'left';
                        }
                        if (data.section === 'body' && data.column.index === 1) {
                            data.cell.styles.fillColor = getChanceColor(data.cell.raw);
                            data.cell.styles.textColor = [17, 24, 39];
                            data.cell.styles.fontStyle = 'bold';
                        }
                    }
                });
                
                addPdfBranding();
                
                const filename = `KCET_${activeCategory}_Cutoffs_${catVal}_Rank${rankVal}.pdf`;
                const pdfData = doc.output('blob');
                const pdfBlob = new Blob([pdfData], { type: 'application/pdf' });
                const url = URL.createObjectURL(pdfBlob);
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setTimeout(() => URL.revokeObjectURL(url), 2000);
            } catch (err) {
                console.error('PDF Generation Error:', err);
                alert('Failed to generate PDF. Check console for details.');
            } finally {
                if (downloadBtn) {
                    downloadBtn.disabled = false;
                    downloadBtn.innerHTML = `<i data-lucide="download" style="width: 18px; height: 18px;"></i> Download Cutoff Report`;
                    lucide.createIcons();
                }
            }
        }
    </script>
</body>
</html>
