<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KCET Multi-Course Predictor</title>
    <link rel="stylesheet" href="/css/index.css">
    
    <!-- Axios for AJAX -->
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <!-- Lucide for Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- jsPDF and AutoTable for Reports -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
</head>
<body>
    <div class="app-container">
        <header>
            <h1>KCET Multi-Course Predictor</h1>
            <p class="subtitle">Check your admission chances across Engineering, Agriculture, Veterinary, Pharmacy, Nursing, BNYS, Allied Health, BPT, and BPO in Karnataka</p>
        </header>

        <div class="category-tabs-container">
            <h2 class="section-title">Select Admission Stream</h2>
            <div class="category-tabs" id="tabs-container">
                <!-- Tabs will load dynamically here -->
            </div>
        </div>

        <div class="glass-panel">
            <form class="search-form" id="searchForm">
                <div class="form-group region-selector-group" style="grid-column: 1 / -1;">
                    <label>Quota Region</label>
                    <div class="region-toggle">
                        <button 
                            type="button" 
                            id="rk-btn"
                            class="region-btn active"
                            onclick="setRegion('RK')"
                        >
                            Rest of Karnataka (General Quota)
                        </button>
                        <button 
                            type="button" 
                            id="hk-btn"
                            class="region-btn"
                            onclick="setRegion('HK')"
                        >
                            Kalyana-Karnataka (371j Quota)
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="rank">Your KCET Rank</label>
                    <input 
                        type="number" 
                        id="rank" 
                        placeholder="e.g., 15000" 
                        required
                        min="1"
                    />
                </div>
                
                <div class="form-group">
                    <label>Quota Category</label>
                    <div class="multi-select-container" id="category-container">
                        <div class="multi-select-trigger" id="category-trigger">
                            <span class="selected-text" id="category-selected-text">Select Category</span>
                            <i data-lucide="chevron-down" style="width: 18px; height: 18px;"></i>
                        </div>
                        <div class="multi-select-dropdown" id="category-dropdown">
                            <div class="dropdown-search-wrapper">
                                <input type="text" placeholder="Search category..." class="dropdown-search" id="category-search" oninput="filterCategories(this.value)">
                            </div>
                            <div class="checkbox-list-controls">
                                <button type="button" class="control-link" id="category-select-all">Select All</button>
                                <button type="button" class="control-link" id="category-clear-all">Clear</button>
                            </div>
                            <div class="checkbox-list" id="category-checkbox-list">
                                <!-- Categories checkboxes will populate here -->
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label id="course-label">Preferred Course (Optional)</label>
                    <div class="multi-select-container" id="course-container">
                        <div class="multi-select-trigger" id="course-trigger">
                            <span class="selected-text" id="course-selected-text">All Courses</span>
                            <i data-lucide="chevron-down" style="width: 18px; height: 18px;"></i>
                        </div>
                        <div class="multi-select-dropdown" id="course-dropdown">
                            <div class="dropdown-search-wrapper">
                                <input type="text" placeholder="Search course..." class="dropdown-search" id="course-search" oninput="filterCourses(this.value)">
                            </div>
                            <div class="checkbox-list-controls">
                                <button type="button" class="control-link" id="course-select-all">Select All</button>
                                <button type="button" class="control-link" id="course-clear-all">Clear</button>
                            </div>
                            <div class="checkbox-list" id="course-checkbox-list">
                                <!-- Courses checkboxes will populate here -->
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn" id="submit-btn">
                    <i data-lucide="search" style="width: 18px; height: 18px;"></i>
                    Find Match Cutoffs
                </button>
            </form>
        </div>

        <div id="results-section" style="display: none;">
            <!-- Predictions will render here dynamically -->
        </div>
    </div>

    <script>
        const rkCategories = [
            '1G', '1K', '1R', '2AG', '2AK', '2AR', '2BG', '2BK', '2BR', 
            '3AG', '3AK', '3AR', '3BG', '3BK', '3BR', 
            'GM', 'GMK', 'GMR', 'SCG', 'SCK', 'SCR', 'STG', 'STK', 'STR'
        ];

        const hkCategories = [
            '1H', '1KH', '1RH', '2AH', '2AKH', '2ARH', '2BH', '2BKH', '2BRH', 
            '3AH', '3AKH', '3ARH', '3BH', '3BKH', '3BRH', 
            'GMH', 'GMKH', 'GMRH', 'SCH', 'SCKH', 'SCRH', 'STH', 'STKH', 'STRH'
        ];

        const categoryIcons = {
            'Engineering': 'cpu',
            'Agriculture': 'leaf',
            'Veterinary': 'award',
            'B.Pharm': 'pill',
            'D.Pharm': 'pill',
            'B.Sc Nursing': 'heart-pulse',
            'BNYS': 'activity',
            'Allied Health Sciences': 'stethoscope',
            'BPT': 'graduation-cap',
            'BPO': 'stethoscope',
            'Architecture': 'compass'
        };

        function getCategoryForCourse(courseName) {
            if (!courseName) return 'Engineering';
            const name = courseName.toUpperCase();
            if (name.includes('ARCHITECTURE')) return 'Architecture';
            if (name.includes('B-PHARMA')) return 'B.Pharm';
            if (name.includes('PHARMA-D') || name.includes('PHARM-D')) return 'D.Pharm';
            if (name.includes('VETERINARY') || name.includes('VETER SCI') || name.includes('B.V.SC')) return 'Veterinary';
            if (name.includes('NURSING')) return 'B.Sc Nursing';
            if (name.includes('BNYS') || name.includes('NATUROPATHY') || name.includes('YOGA')) return 'BNYS';
            if (name.includes('PHYSIOTHERAPY') || name.includes('BPT')) return 'BPT';
            if (name.includes('PROSTHETICS ORTHOTICS') || name.includes('BPO')) return 'BPO';
            if (name.includes('OPTOMETRY')) return 'BPO';
            
            // Agriculture and Farm Sciences
            if (name.includes('AGRICULTURE') || name.includes('AGRI') || name.includes('FORESTRY') || 
                name.includes('HORTICULTURE') || name.includes('SERICULTURE') || name.includes('FISHERIES') || 
                name.includes('FOOD SCI') || name.includes('DAIRY') || name.includes('NUTRITION') || 
                name.includes('DIETETICS') || name.includes('COMMUNITY SCIENCE') || name.includes('FOOD TECHNOLOGY') || 
                name.includes('FOOD TECH') || name.includes('AG. ') || name.includes('D.TECH')) {
                return 'Agriculture';
            }
            
            // Allied Health Sciences
            if (name.includes('AHS') || name.includes('OPERATION THEATER') || name.includes('OCCUPATIONAL') || 
                name.includes('AUDIOLOGY') || name.includes('ANAEST') || name.includes('CARDIAC') || 
                name.includes('TRAUMA') || name.includes('IMAGING') || name.includes('LAB') || 
                name.includes('NEURO') || name.includes('PERFUSION') || name.includes('RADIOTHERAPY') || 
                name.includes('RENAL') || name.includes('RESP') || name.includes('HOSP. ADMIN') || 
                name.includes('RECORD TECH') || name.includes('PUBLIC HEALTH')) {
                return 'Allied Health Sciences';
            }
            
            return 'Engineering';
        }

        let activeCategory = 'Engineering';
        let categories = [];
        let courses = [];
        let results = [];
        let quotaRegion = 'RK';
        let pdfLoading = false;
        let searched = false;
        let selectedCategories = [];
        let selectedCourses = [];

        document.addEventListener('DOMContentLoaded', async () => {
            // Fetch categories list
            try {
                const res = await axios.get('/api/categories');
                categories = res.data;
            } catch (err) {
                console.error("Error fetching categories:", err);
                categories = [
                    'Engineering', 'Agriculture', 'Veterinary', 'B.Pharm', 'D.Pharm',
                    'B.Sc Nursing', 'BNYS', 'Allied Health Sciences', 'BPT', 'BPO', 'Architecture'
                ];
            }

            renderCategoryTabs();
            updateCategoryDropdown();
            loadCourses();
            setupMultiSelectDropdowns();
        });

        function renderCategoryTabs() {
            const container = document.getElementById('tabs-container');
            let html = '';
            categories.forEach(cat => {
                const iconName = categoryIcons[cat] || 'book-open';
                const activeClass = activeCategory === cat ? 'active' : '';
                html += `
                    <button 
                        type="button" 
                        class="category-tab ${activeClass}" 
                        onclick="setActiveCategory('${cat}')"
                    >
                        <span class="tab-icon"><i data-lucide="${iconName}" style="width: 18px; height: 18px;"></i></span>
                        <span class="tab-label">${cat}</span>
                    </button>
                `;
            });
            container.innerHTML = html;
            lucide.createIcons();
        }

        function setActiveCategory(cat) {
            activeCategory = cat;
            document.getElementById('results-section').style.display = 'none';
            searched = false;
            
            // Clear search fields and show all options
            document.getElementById('course-search').value = '';
            document.getElementById('category-search').value = '';
            filterCourses('');
            filterCategories('');
            
            // Re-render tabs
            renderCategoryTabs();
            
            // Update label
            document.getElementById('course-label').textContent = `Preferred Course (Optional)`;
            
            // Clear selections but don't fetch from server again since all courses are already loaded
            selectedCourses = [];
            updateCourseTriggerText();
            renderCourseCheckboxes();
        }

        async function loadCourses() {
            const listContainer = document.getElementById('course-checkbox-list');
            listContainer.innerHTML = `<div style="padding: 0.5rem; font-size: 0.9rem; color: var(--text-secondary);">Loading courses...</div>`;
            selectedCourses = [];
            updateCourseTriggerText();
            
            try {
                const res = await axios.get(`/api/courses`);
                courses = res.data;
                renderCourseCheckboxes();
            } catch (err) {
                console.error(err);
                listContainer.innerHTML = `<div style="padding: 0.5rem; font-size: 0.9rem; color: var(--danger-color);">Error loading courses</div>`;
            }
        }

        function renderCourseCheckboxes() {
            const listContainer = document.getElementById('course-checkbox-list');
            
            // Filter courses to only include those belonging to the active Category/Stream tab
            const filteredCourses = courses.filter(c => getCategoryForCourse(c) === activeCategory);
            
            if (filteredCourses.length === 0) {
                listContainer.innerHTML = `<div style="padding: 0.5rem; font-size: 0.9rem; color: var(--text-secondary);">No courses available</div>`;
                return;
            }
            let html = '';
            filteredCourses.forEach(c => {
                const checked = selectedCourses.includes(c) ? 'checked' : '';
                html += `
                    <label class="checkbox-option" data-value="${c}">
                        <input type="checkbox" value="${c}" ${checked} onchange="handleCourseChange(this)">
                        <span title="${c}">${c}</span>
                    </label>
                `;
            });
            listContainer.innerHTML = html;
        }

        function handleCourseChange(checkbox) {
            const val = checkbox.value;
            if (checkbox.checked) {
                if (!selectedCourses.includes(val)) {
                    selectedCourses.push(val);
                }
            } else {
                selectedCourses = selectedCourses.filter(c => c !== val);
            }
            updateCourseTriggerText();
        }

        function updateCourseTriggerText() {
            const selectedText = document.getElementById('course-selected-text');
            if (selectedCourses.length === 0) {
                selectedText.textContent = `All ${activeCategory} Courses`;
            } else if (selectedCourses.length === 1) {
                selectedText.textContent = selectedCourses[0];
            } else {
                selectedText.textContent = `${selectedCourses.length} Courses Selected`;
            }
        }

        function setRegion(region) {
            quotaRegion = region;
            document.getElementById('results-section').style.display = 'none';
            searched = false;

            // Clear search fields and show all options
            document.getElementById('course-search').value = '';
            document.getElementById('category-search').value = '';
            filterCourses('');
            filterCategories('');

            if (region === 'RK') {
                document.getElementById('rk-btn').classList.add('active');
                document.getElementById('hk-btn').classList.remove('active');
            } else {
                document.getElementById('hk-btn').classList.add('active');
                document.getElementById('rk-btn').classList.remove('active');
            }

            updateCategoryDropdown();
        }

        function updateCategoryDropdown() {
            const list = quotaRegion === 'RK' ? rkCategories : hkCategories;
            const defaultCat = quotaRegion === 'RK' ? 'GM' : 'GMH';
            selectedCategories = [defaultCat];
            
            renderCategoryCheckboxes(list);
            updateCategoryTriggerText();
        }

        function renderCategoryCheckboxes(list) {
            const listContainer = document.getElementById('category-checkbox-list');
            let html = '';
            list.forEach(c => {
                const checked = selectedCategories.includes(c) ? 'checked' : '';
                html += `
                    <label class="checkbox-option" data-value="${c}">
                        <input type="checkbox" value="${c}" ${checked} onchange="handleCategoryChange(this)">
                        <span>${c}</span>
                    </label>
                `;
            });
            listContainer.innerHTML = html;
        }

        function handleCategoryChange(checkbox) {
            const val = checkbox.value;
            if (checkbox.checked) {
                if (!selectedCategories.includes(val)) {
                    selectedCategories.push(val);
                }
            } else {
                selectedCategories = selectedCategories.filter(c => c !== val);
            }
            updateCategoryTriggerText();
        }

        function updateCategoryTriggerText() {
            const selectedText = document.getElementById('category-selected-text');
            if (selectedCategories.length === 0) {
                selectedText.textContent = 'Select Category';
            } else if (selectedCategories.length === 1) {
                selectedText.textContent = selectedCategories[0];
            } else {
                selectedText.textContent = `${selectedCategories.length} Categories Selected`;
            }
        }

        // Global search filtering functions
        function normalizeText(str) {
            if (!str) return '';
            return str.toLowerCase()
                .replace(/[^a-z0-9]/g, '') // remove spaces and non-alphanumeric
                .replace(/artifical/g, 'artificial')
                .replace(/sicence/g, 'science')
                .replace(/virutal/g, 'virtual')
                .replace(/mathamatics/g, 'mathematics')
                .replace(/pharmaceutic/g, 'pharmaceutical')
                .replace(/dpharm/g, 'pharmd')
                .replace(/pharmad/g, 'pharmd')
                .replace(/bpharma/g, 'bpharm');
        }

        function matchCourse(courseName, query) {
            const normCourse = normalizeText(courseName);
            const normQuery = normalizeText(query);
            
            // Check direct substring match after normalization
            if (normCourse.includes(normQuery)) {
                return true;
            }
            
            // Check abbreviation expansions
            const lowerQuery = query.toLowerCase().trim();
            if (lowerQuery === 'cs' || lowerQuery === 'cse') {
                if (normCourse.includes('computerscience')) return true;
            }
            if (lowerQuery === 'is' || lowerQuery === 'ise') {
                if (normCourse.includes('informationscience')) return true;
            }
            if (lowerQuery === 'ec' || lowerQuery === 'ece') {
                if (normCourse.includes('electronics') && (normCourse.includes('communication') || normCourse.includes('communicatio'))) return true;
            }
            if (lowerQuery === 'ee' || lowerQuery === 'eee') {
                if (normCourse.includes('electrical') && normCourse.includes('electronics')) return true;
            }
            if (lowerQuery === 'me' || lowerQuery === 'mech') {
                if (normCourse.includes('mechanical')) return true;
            }
            if (lowerQuery === 'cv' || lowerQuery === 'ce') {
                if (normCourse.includes('civil')) return true;
            }
            if (lowerQuery === 'bt') {
                if (normCourse.includes('biotech') || normCourse.includes('biotechnology')) return true;
            }
            if (lowerQuery === 'ai' || lowerQuery === 'ml' || lowerQuery === 'aiml') {
                if (normCourse.includes('artificialintelligence') || normCourse.includes('machinelearning') || normCourse.includes('aiml')) return true;
            }
            if (lowerQuery === 'iot') {
                if (normCourse.includes('internetofthings') || normCourse.includes('iot')) return true;
            }
            if (lowerQuery === 'ag' || lowerQuery === 'agri') {
                if (normCourse.includes('agriculture') || normCourse.includes('agbusiness') || normCourse.includes('agri')) return true;
            }
            
            // Check if query words are all present in the course name
            const queryWords = query.toLowerCase().split(/\s+/).filter(Boolean);
            if (queryWords.length > 1) {
                return queryWords.every(word => {
                    const normWord = normalizeText(word);
                    return normCourse.includes(normWord);
                });
            }
            
            return false;
        }

        function filterCategories(term) {
            const query = term.toLowerCase().trim();
            const options = document.querySelectorAll('#category-checkbox-list .checkbox-option');
            options.forEach(opt => {
                const text = opt.querySelector('span').textContent.toLowerCase();
                opt.style.display = text.includes(query) ? 'flex' : 'none';
            });
        }

        function filterCourses(term) {
            const query = term.trim();
            const options = document.querySelectorAll('#course-checkbox-list .checkbox-option');
            options.forEach(opt => {
                const courseName = opt.querySelector('span').textContent;
                if (!query) {
                    opt.style.display = 'flex';
                } else {
                    opt.style.display = matchCourse(courseName, query) ? 'flex' : 'none';
                }
            });
        }

        function setupMultiSelectDropdowns() {
            const categoryTrigger = document.getElementById('category-trigger');
            const categoryDropdown = document.getElementById('category-dropdown');
            const courseTrigger = document.getElementById('course-trigger');
            const courseDropdown = document.getElementById('course-dropdown');

            categoryTrigger.addEventListener('click', (e) => {
                e.stopPropagation();
                categoryTrigger.classList.toggle('active');
                const show = categoryTrigger.classList.contains('active');
                categoryDropdown.style.display = show ? 'flex' : 'none';
                
                // Close course dropdown
                courseTrigger.classList.remove('active');
                courseDropdown.style.display = 'none';
            });

            courseTrigger.addEventListener('click', (e) => {
                e.stopPropagation();
                courseTrigger.classList.toggle('active');
                const show = courseTrigger.classList.contains('active');
                courseDropdown.style.display = show ? 'flex' : 'none';
                
                // Close category dropdown
                categoryTrigger.classList.remove('active');
                categoryDropdown.style.display = 'none';
            });

            document.addEventListener('click', (e) => {
                if (!document.getElementById('category-container').contains(e.target)) {
                    categoryTrigger.classList.remove('active');
                    categoryDropdown.style.display = 'none';
                }
                if (!document.getElementById('course-container').contains(e.target)) {
                    courseTrigger.classList.remove('active');
                    courseDropdown.style.display = 'none';
                }
            });

            // Prevent closing on clicking inside
            categoryDropdown.addEventListener('click', (e) => e.stopPropagation());
            courseDropdown.addEventListener('click', (e) => e.stopPropagation());

            // Prevent Enter key in search from submitting the form
            document.getElementById('category-search').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });
            document.getElementById('course-search').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                }
            });

            // Select all / Clear all
            document.getElementById('category-select-all').addEventListener('click', () => {
                const options = document.querySelectorAll('#category-checkbox-list .checkbox-option');
                options.forEach(opt => {
                    if (opt.style.display !== 'none') {
                        const cb = opt.querySelector('input[type="checkbox"]');
                        if (cb && !cb.checked) {
                            cb.checked = true;
                            if (!selectedCategories.includes(cb.value)) {
                                selectedCategories.push(cb.value);
                            }
                        }
                    }
                });
                updateCategoryTriggerText();
            });

            document.getElementById('category-clear-all').addEventListener('click', () => {
                const options = document.querySelectorAll('#category-checkbox-list .checkbox-option');
                options.forEach(opt => {
                    if (opt.style.display !== 'none') {
                        const cb = opt.querySelector('input[type="checkbox"]');
                        if (cb && cb.checked) {
                            cb.checked = false;
                            selectedCategories = selectedCategories.filter(c => c !== cb.value);
                        }
                    }
                });
                updateCategoryTriggerText();
            });

            document.getElementById('course-select-all').addEventListener('click', () => {
                const options = document.querySelectorAll('#course-checkbox-list .checkbox-option');
                options.forEach(opt => {
                    if (opt.style.display !== 'none') {
                        const cb = opt.querySelector('input[type="checkbox"]');
                        if (cb && !cb.checked) {
                            cb.checked = true;
                            if (!selectedCourses.includes(cb.value)) {
                                selectedCourses.push(cb.value);
                            }
                        }
                    }
                });
                updateCourseTriggerText();
            });

            document.getElementById('course-clear-all').addEventListener('click', () => {
                const options = document.querySelectorAll('#course-checkbox-list .checkbox-option');
                options.forEach(opt => {
                    if (opt.style.display !== 'none') {
                        const cb = opt.querySelector('input[type="checkbox"]');
                        if (cb && cb.checked) {
                            cb.checked = false;
                            selectedCourses = selectedCourses.filter(c => c !== cb.value);
                        }
                    }
                });
                updateCourseTriggerText();
            });
        }

        // Form Submission
        document.getElementById('searchForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const rankVal = document.getElementById('rank').value;
            const submitBtn = document.getElementById('submit-btn');
            
            if (!rankVal) return;
            if (selectedCategories.length === 0) {
                alert('Please select at least one Quota Category.');
                return;
            }
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Evaluating...';

            const resultsContainer = document.getElementById('results-section');
            resultsContainer.style.display = 'block';
            resultsContainer.innerHTML = `
                <div class="empty-state">
                    <div class="spinner">Evaluating college criteria...</div>
                </div>
            `;
            
            try {
                const params = {
                    rank: rankVal,
                    category: selectedCategories.join(',')
                };
                if (selectedCourses.length > 0) {
                    params.course_name = selectedCourses.join(',');
                } else {
                    params.course_category = activeCategory;
                }

                const res = await axios.get(`/api/predict`, { params });
                results = res.data;
                searched = true;
                renderResults();
            } catch (err) {
                console.error(err);
                resultsContainer.innerHTML = `
                    <div class="glass-panel empty-state">
                        <h3>Error evaluating options</h3>
                        <p>Please try again later.</p>
                    </div>
                `;
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = `<i data-lucide="search" style="width: 18px; height: 18px;"></i> Find Match Cutoffs`;
                lucide.createIcons();
            }
        });

        function renderResults() {
            const resultsContainer = document.getElementById('results-section');
            if (results.length === 0) {
                resultsContainer.innerHTML = `
                    <div class="glass-panel empty-state">
                        <i data-lucide="compass" class="empty-icon" style="width: 48px; height: 48px;"></i>
                        <h3>No colleges found in this range</h3>
                        <p>Try modifying your category or rank preferences.</p>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            let cardsHtml = '';
            results.forEach(result => {
                cardsHtml += `
                    <div class="college-card chances-${result.chances}">
                        <div class="card-header">
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                <span class="college-code">${result.college_code}</span>
                                <span class="college-code" style="background: rgba(99, 102, 241, 0.2); color: #818cf8;">${result.category}</span>
                            </div>
                            <span class="badge ${result.chances}">${result.chances}</span>
                        </div>
                        <h3 class="college-name">${result.college_name}</h3>
                        <div class="course-name">
                            <i data-lucide="book-open" style="width: 14px; height: 14px; display: inline-block; margin-right: 6px; vertical-align: middle;"></i>
                            ${result.course_name}
                        </div>
                        
                        <div class="stats">
                            <div class="stat-item">
                                <span class="stat-label">Previous Cutoff</span>
                                <span class="stat-value">${result.cutoff_rank}</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Year / Round</span>
                                <span class="stat-value">${result.year} / R${result.round}</span>
                            </div>
                        </div>
                    </div>
                `;
            });

            resultsContainer.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 3rem; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
                    <h2 style="font-weight: 600; font-size: 1.75rem;">
                        Prediction Results (${results.length} matched) <span style="font-size: 0.9rem; color: #10b981; background: rgba(16, 185, 129, 0.15); padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 500; margin-left: 0.5rem;"><i data-lucide="check" style="width: 12px; height: 12px; display: inline-block; vertical-align: middle; margin-right: 4px;"></i>Free Report</span>
                    </h2>
                    <button onclick="generatePDF()" id="pdf-download-btn" class="btn btn-download" style="background: #10b981; height: auto; padding: 0.6rem 1.2rem; margin-top: 0;">
                        <i data-lucide="download" style="width: 18px; height: 18px;"></i>
                        Download ${activeCategory} Cutoff Report
                    </button>
                </div>
                <div class="results-grid">
                    ${cardsHtml}
                </div>
            `;
            lucide.createIcons();
        }

        async function generatePDF() {
            const downloadBtn = document.getElementById('pdf-download-btn');
            if (downloadBtn) {
                downloadBtn.disabled = true;
                downloadBtn.innerHTML = 'Generating PDF...';
            }
            
            try {
                const rankVal = document.getElementById('rank').value;
                
                const params = new URLSearchParams({ category: selectedCategories.join(',') });
                if (selectedCourses.length > 0) params.append('course_name', selectedCourses.join(','));
                if (activeCategory) params.append('course_category', activeCategory);
                
                const response = await axios.get(`/api/cutoffs?${params.toString()}`);
                let rows = response.data;
                
                // Filter to only include college + course + category combinations present in the prediction results
                const allowedCombinations = new Set(results.map(r => `${r.college_code}|${r.course_name}|${r.category}`));
                rows = rows.filter(r => allowedCombinations.has(`${r.college_code}|${r.course_name}|${r.category}`));
                
                if (!rows || rows.length === 0) {
                    alert('No cutoff data available for the selected inputs.');
                    if (downloadBtn) {
                        downloadBtn.disabled = false;
                        downloadBtn.innerHTML = `<i data-lucide="download" style="width: 18px; height: 18px;"></i> Download Cutoff Report`;
                        lucide.createIcons();
                    }
                    return;
                }
                
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ orientation: 'landscape', format: 'a4' });
                
                const addPdfBranding = () => {
                    const totalPages = doc.internal.getNumberOfPages();
                    const pageWidth = doc.internal.pageSize.getWidth();
                    const pageHeight = doc.internal.pageSize.getHeight();
                    const footerText = `EDU YODHA | Generated on ${new Date().toLocaleString()}`;
                    
                    for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) {
                        doc.setPage(pageNumber);
                        
                        doc.saveGraphicsState();
                        doc.setGState(new doc.GState({ opacity: 0.04 }));
                        doc.setFont('helvetica', 'bold');
                        doc.setFontSize(42);
                        doc.setTextColor(45, 55, 72);
                        
                        for (let y = 18; y < pageHeight + 80; y += 58) {
                            for (let x = -35; x < pageWidth + 80; x += 105) {
                                doc.text('EDU YODHA', x, y, { angle: -28 });
                            }
                        }
                        
                        doc.restoreGraphicsState();
                        doc.setFont('helvetica', 'normal');
                        doc.setFontSize(9);
                        doc.setTextColor(100);
                        doc.text(footerText, 14, pageHeight - 10);
                        doc.text(`Page ${pageNumber} of ${totalPages}`, pageWidth - 34, pageHeight - 10);
                    }
                };
                
                doc.setFontSize(18);
                doc.text('KCET Cutoff History Report', 14, 20);
                doc.setFontSize(12);
                
                const categoriesStr = selectedCategories.length > 5 
                    ? `${selectedCategories.slice(0, 5).join(', ')}... (+${selectedCategories.length - 5} more)`
                    : selectedCategories.join(', ');
                doc.text(`Category: ${categoriesStr} | User Rank: ${rankVal} | Stream: ${activeCategory}`, 14, 28);
                
                if (selectedCourses.length > 0) {
                    const coursesStr = selectedCourses.length > 3
                        ? `${selectedCourses.slice(0, 3).join(', ')}... (+${selectedCourses.length - 3} more)`
                        : selectedCourses.join(', ');
                    doc.text(`Preferred Course: ${coursesStr}`, 14, 34);
                } else {
                    doc.text(`Preferred Course: All Courses`, 14, 34);
                }
                
                doc.text('Full cutoff history for 2023, 2024, and 2025 (Rounds 1–3)', 14, 40);
                
                // Group cutoff rows by Category, then by Course Name, then by College
                const groups = {};
                rows.forEach(r => {
                    const cat = r.category;
                    const course = r.course_name;
                    const college = r.college_name;
                    
                    if (!groups[cat]) {
                        groups[cat] = {};
                    }
                    if (!groups[cat][course]) {
                        groups[cat][course] = {};
                    }
                    if (!groups[cat][course][college]) {
                        groups[cat][course][college] = {
                            college_name: college,
                            '2023_1': '-', '2023_2': '-', '2023_3': '-',
                            '2024_1': '-', '2024_2': '-', '2024_3': '-',
                            '2025_1': '-', '2025_2': '-', '2025_3': '-',
                        };
                    }
                    if (r.year && r.round) {
                        groups[cat][course][college][`${r.year}_${r.round}`] = r.cutoff_rank;
                    }
                });
                
                const getMinRank = (g) => {
                    const values = [
                        g['2023_1'], g['2023_2'], g['2023_3'],
                        g['2024_1'], g['2024_2'], g['2024_3'],
                        g['2025_1'], g['2025_2'], g['2025_3']
                    ]
                    .filter(v => v !== '-' && v !== null && v !== undefined)
                    .map(v => parseInt(v, 10))
                    .filter(Number.isFinite);
                    return values.length ? Math.min(...values) : Number.MAX_SAFE_INTEGER;
                };
                
                const getChance = (g) => {
                    const cutoffs = [
                        g['2023_1'], g['2023_2'], g['2023_3'],
                        g['2024_1'], g['2024_2'], g['2024_3'],
                        g['2025_1'], g['2025_2'], g['2025_3']
                    ]
                    .filter(v => v !== '-' && v !== null && v !== undefined)
                    .map(v => parseInt(v, 10))
                    .filter(Number.isFinite);
                    if (!cutoffs.length) return 'Tough';
                    const minCutoff = Math.min(...cutoffs);
                    const userRank = parseInt(rankVal, 10);
                    if (userRank <= minCutoff * 0.8) return 'Safe';
                    if (userRank <= minCutoff) return 'Moderate';
                    return 'Tough';
                };
                
                const getChanceColor = (chance) => {
                    if (chance === 'Safe') return [187, 247, 208];
                    if (chance === 'Moderate') return [254, 249, 195];
                    return [254, 202, 202];
                };
                
                const getCategoryOrder = (cat) => {
                    let index = rkCategories.indexOf(cat);
                    if (index === -1) index = hkCategories.indexOf(cat);
                    if (index === -1) return 999;
                    return index;
                };
                
                const sortedCategories = Object.keys(groups).sort((a, b) => getCategoryOrder(a) - getCategoryOrder(b));
                let startY = 48;
                
                sortedCategories.forEach((cat, catIdx) => {
                    const coursesObj = groups[cat];
                    const sortedCourses = Object.keys(coursesObj).sort((a, b) => a.localeCompare(b));
                    
                    if (catIdx > 0 && startY < doc.internal.pageSize.getHeight() - 50) {
                        startY += 8;
                    }
                    
                    sortedCourses.forEach((course, courseIdx) => {
                        const collegesObj = coursesObj[course];
                        
                        const sortedColleges = Object.values(collegesObj).sort((a, b) => {
                            const aMin = getMinRank(a);
                            const bMin = getMinRank(b);
                            if (aMin !== bMin) return aMin - bMin;
                            return a.college_name.localeCompare(b.college_name);
                        });
                        
                        if (startY > doc.internal.pageSize.getHeight() - 45) {
                            doc.addPage();
                            startY = 20;
                        }
                        
                        doc.setFont('helvetica', 'bold');
                        doc.setFontSize(11);
                        doc.setTextColor(30, 41, 59);
                        doc.text(`Quota Category: ${cat}   |   Course: ${course}`, 14, startY);
                        startY += 5;
                        
                        const tableColumn = [
                            'College Name',
                            'Chance',
                            '2023 R1', '2023 R2', '2023 R3',
                            '2024 R1', '2024 R2', '2024 R3',
                            '2025 R1', '2025 R2', '2025 R3'
                        ];
                        
                        const tableRows = sortedColleges.map(g => [
                            g.college_name,
                            getChance(g),
                            g['2023_1'], g['2023_2'], g['2023_3'],
                            g['2024_1'], g['2024_2'], g['2024_3'],
                            g['2025_1'], g['2025_2'], g['2025_3']
                        ]);
                        
                        doc.autoTable({
                            startY: startY,
                            head: [tableColumn],
                            body: tableRows,
                            theme: 'grid',
                            styles: { fontSize: 8, cellPadding: 2 },
                            headStyles: { fillColor: [49, 46, 129], textColor: [255, 255, 255], halign: 'center' },
                            columnStyles: { 
                                0: { cellWidth: 130, halign: 'left' }, 
                                1: { cellWidth: 22, fontStyle: 'bold', halign: 'center' } 
                            },
                            bodyStyles: { halign: 'center' },
                            didParseCell: data => {
                                if (data.section === 'body' && data.column.index === 0) {
                                    data.cell.styles.halign = 'left';
                                }
                                if (data.section === 'body' && data.column.index === 1) {
                                    data.cell.styles.fillColor = getChanceColor(data.cell.raw);
                                    data.cell.styles.textColor = [17, 24, 39];
                                    data.cell.styles.fontStyle = 'bold';
                                }
                            },
                            margin: { bottom: 15 }
                        });
                        
                        startY = doc.lastAutoTable.finalY + 12;
                    });
                });
                
                addPdfBranding();
                
                const catFileStr = selectedCategories.length > 3 
                    ? `${selectedCategories.slice(0, 3).join('_')}_multi` 
                    : selectedCategories.join('_');
                const filename = `KCET_${activeCategory}_Cutoffs_${catFileStr}_Rank${rankVal}.pdf`;
                const pdfData = doc.output('blob');
                const pdfBlob = new Blob([pdfData], { type: 'application/pdf' });
                const url = URL.createObjectURL(pdfBlob);
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                setTimeout(() => URL.revokeObjectURL(url), 2000);
            } catch (err) {
                console.error('PDF Generation Error:', err);
                alert('Failed to generate PDF. Check console for details.');
            } finally {
                if (downloadBtn) {
                    downloadBtn.disabled = false;
                    downloadBtn.innerHTML = `<i data-lucide="download" style="width: 18px; height: 18px;"></i> Download Cutoff Report`;
                    lucide.createIcons();
                }
            }
        }
    </script>
</body>
</html>
